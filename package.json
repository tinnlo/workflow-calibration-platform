{
    "name": "workflow-calibration-platform",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "workspaces": [
        "server"
    ],
    "scripts": {
        "dev": "concurrently -n fe,be -c cyan,green \"vite\" \"npm run dev --workspace=server\"",
        "build": "tsc -b && vite build",
        "build:server": "npm run build --workspace=server",
        "build:all": "npm run build && npm run build:server",
        "preview": "vite preview",
        "lint": "eslint .",
        "lint:server": "npm run lint --workspace=server",
        "lint:all": "npm run lint && npm run lint:server",
        "typecheck": "tsc -b",
        "typecheck:server": "npm run typecheck --workspace=server",
        "typecheck:all": "npm run typecheck && npm run typecheck:server",
        "test": "vitest run",
        "test:server": "npm test --workspace=server",
        "test:all": "vitest run && npm run test:server",
        "test:watch": "vitest",
        "test:e2e": "playwright test"
    },
    "dependencies": {
        "@hookform/resolvers": "^3.9.0",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.1",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-select": "^2.1.1",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toast": "^1.2.15",
        "@radix-ui/react-tooltip": "^1.1.4",
        "@tanstack/react-query": "^5.56.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "jspdf": "^3.0.2",
        "jspdf-autotable": "^5.0.2",
        "lucide-react": "^0.462.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-hook-form": "^7.53.0",
        "react-router-dom": "^6.26.2",
        "recharts": "^2.12.7",
        "sonner": "^1.5.0",
        "tailwind-merge": "^2.5.2",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@eslint/js": "^9.9.0",
        "@playwright/test": "^1.58.2",
        "@testing-library/jest-dom": "^6.8.0",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^22.5.5",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react-swc": "^3.5.0",
        "@vitest/ui": "^3.2.4",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.0.0",
        "eslint": "^9.9.0",
        "eslint-plugin-react-hooks": "^5.1.0-rc.0",
        "eslint-plugin-react-refresh": "^0.4.9",
        "globals": "^15.9.0",
        "jsdom": "^26.1.0",
        "postcss": "^8.4.47",
        "tailwindcss": "^3.4.11",
        "typescript": "^5.5.3",
        "typescript-eslint": "^8.0.1",
        "vite": "^5.4.1",
        "vitest": "^3.2.4"
    }
}
